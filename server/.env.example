## Server environment variables (example)
# Copy to `.env` (never commit real secrets).

# Core
PORT=3000
MONGO_URI=mongodb://localhost:27017/ticket-ai
JWT_SECRET=change-me-to-a-long-random-secret

# CORS (comma-separated origins)
# Example dev: http://localhost:5173
# Example prod: https://app.yourdomain.com
CORS_ORIGINS=http://localhost:5173

# Inngest
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key
# Optional override
GEMINI_MODEL=gemini-2.5-flash

# SMTP (Mailtrap example)
MAILTRAP_SMTP_HOST=smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USER=your_mailtrap_user
MAILTRAP_SMTP_PASS=your_mailtrap_pass

